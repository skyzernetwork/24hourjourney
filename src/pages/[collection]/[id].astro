---
import { getCollection, render } from 'astro:content';
import PostLayout from '@/layouts/PostLayout.astro';

export async function getStaticPaths() {
  const collections = [
    'for-business',
    'design',
    'portfolios',
    'behind-the-build',
    'guides',
    'case-studies',
  ] as const;

  const allPaths = (
    await Promise.all(
      collections.map(async (col) => {
        const entries = await getCollection(col).catch(() => []);
        return entries
          .filter((entry) => !entry.data.draft)
          .map((entry) => ({
            params: { collection: col, id: entry.id },
            props:  { entry, collection: col },
          }));
      })
    )
  ).flat();

  return allPaths;
}

const { entry, collection } = Astro.props;
const { Content } = await render(entry);
const { title, description, pubDate, author, category, subcategory, tags, cover } = entry.data;
---

<PostLayout
  title={title}
  description={description}
  pubDate={pubDate}
  author={author}
  category={collection}
  subcategory={subcategory}
  tags={tags}
  cover={cover}
>
  <Content />
</PostLayout>