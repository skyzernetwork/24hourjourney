---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getPostImage } from '@/lib/getPostImage';

const allPosts = (await Promise.all([
  getCollection('for-business').catch((e) => { console.error('for-business:', e); return []; }),
  getCollection('design').catch((e) => { console.error('design:', e); return []; }),
  getCollection('portfolios').catch((e) => { console.error('portfolios:', e); return []; }),
  getCollection('behind-the-build').catch((e) => { console.error('behind-the-build:', e); return []; }),
  getCollection('guides').catch((e) => { console.error('guides:', e); return []; }),
  getCollection('case-studies').catch((e) => { console.error('case-studies:', e); return []; }),
])).flat().filter(p => !p.data.draft);

const sorted = allPosts.sort((a, b) =>
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const featured = sorted.find(p => p.data.featured) ?? sorted[0];
const recent = sorted.filter(p => p !== featured).slice(0, 4);

const behindTheBuild = (await getCollection('behind-the-build').catch(() => []))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const categoryMeta: Record<string, { label: string; abbr: string; colorClass: string; dotClass: string }> = {
  'for-business':     { label: 'For Business',     abbr: 'BIZ',    colorClass: 'tag-c', dotClass: 'dot-c' },
  'design':           { label: 'Design',            abbr: 'DESIGN', colorClass: 'tag-m', dotClass: 'dot-m' },
  'portfolios':       { label: 'Portfolios',        abbr: 'PORT',   colorClass: 'tag-g', dotClass: 'dot-g' },
  'behind-the-build': { label: 'Behind the Build',  abbr: 'BUILD',  colorClass: 'tag-a', dotClass: 'dot-a' },
  'guides':           { label: 'Guides',            abbr: 'GUIDE',  colorClass: 'tag-w', dotClass: 'dot-w' },
  'case-studies':     { label: 'Case Study',        abbr: 'CASE',   colorClass: 'tag-c', dotClass: 'dot-c' },
};

const subMeta: Record<string, { label: string; colorClass: string }> = {
  'case-study':      { label: 'Case Study',      colorClass: 'tag-c' },  
  'for-business':    { label: 'For Business',     colorClass: 'tag-c' },  
  'design':          { label: 'Design',           colorClass: 'tag-m' },
  'portfolio-build': { label: 'Portfolio Build',  colorClass: 'tag-g' }, 
  'redesign':        { label: 'Redesign',         colorClass: 'tag-a' },  
  'branding':        { label: 'Branding',         colorClass: 'tag-a' }, 
  'guide':           { label: 'Guide',            colorClass: 'tag-w' },
  'ecommerce':       { label: 'E-Commerce',       colorClass: 'tag-w' }, 
};

const collectionCounts = {
  'for-business':     (await getCollection('for-business').catch(() => [])).filter(p => !p.data.draft).length,
  'design':           (await getCollection('design').catch(() => [])).filter(p => !p.data.draft).length,
  'portfolios':       (await getCollection('portfolios').catch(() => [])).filter(p => !p.data.draft).length,
  'behind-the-build': (await getCollection('behind-the-build').catch(() => [])).filter(p => !p.data.draft).length,
  'guides':           (await getCollection('guides').catch(() => [])).filter(p => !p.data.draft).length,
  'case-studies':     (await getCollection('case-studies').catch(() => [])).filter(p => !p.data.draft).length,
};

// Pre-resolve cover images for recent posts
const recentWithImages = await Promise.all(
  recent.map(async (post) => ({
    post,
    coverImage: post.data.cover ? await getPostImage(post.data.cover) : null,
  }))
);

// Pull case studies for sidebar
const caseStudies = (await getCollection('case-studies').catch(() => []))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);
---

<Layout>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-stripe"></div>
    <div class="hero-left">
      <div class="hero-eyebrow">A blog by Skyzer Networks</div>
      <h1 class="hero-title">
        Your website
        <span class="hero-gradient">can do more</span>
        than you think.
      </h1>
      <p class="hero-body">Tips, stories, and honest advice for small businesses and creators who want an online presence that actually works for them.</p>
      <div class="hero-ctas">
        <a href="/posts" class="btn-outline">Browse all posts</a>
        {sorted[0] && (
          <a href={`/${sorted[0].collection}/${sorted[0].id}`} class="btn-ghost">Latest post &nbsp;→</a>
        )}
      </div>
    </div>
    <div class="hero-right">
      {featured ? (
        <div class="featured-card">
          <div class="featured-card-header">
            <span class="feat-badge">Featured</span>
            <h2 class="featured-card-title">{featured.data.title}</h2>
            <div class="featured-card-meta">
              <span>{featured.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              <span>5 min read</span>
            </div>
          </div>
          <div class="featured-card-body">
            <p>{featured.data.description}</p>
            <a href={`/${featured.collection}/${featured.id}`} class="read-more">Read full post</a>
          </div>
        </div>
      ) : (
        <div class="featured-card">
          <div class="featured-card-header">
            <span class="feat-badge">Coming Soon</span>
            <h2 class="featured-card-title">First post dropping soon.</h2>
            <div class="featured-card-meta"><span>Stay tuned</span></div>
          </div>
          <div class="featured-card-body">
            <p>We're working on something good. Check back shortly.</p>
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- CATEGORY STRIP -->
  <div class="cat-strip">
    <a class="cat-item" href="/for-business">
      <div class="cat-name">For Business</div>
      <div class="cat-desc">Websites, online presence &amp; growth tips</div>
    </a>
    <a class="cat-item" href="/design">
      <div class="cat-name">Design</div>
      <div class="cat-desc">What makes a site look &amp; feel great</div>
    </a>
    <a class="cat-item" href="/portfolios">
      <div class="cat-name">Portfolios</div>
      <div class="cat-desc">Show your work the right way</div>
    </a>
    <a class="cat-item" href="/behind-the-build">
      <div class="cat-name">Behind the Build</div>
      <div class="cat-desc">Real Skyzer project breakdowns</div>
    </a>
    <a class="cat-item" href="/guides">
      <div class="cat-name">Guides</div>
      <div class="cat-desc">Beginner-friendly how-tos</div>
    </a>
  </div>

  <!-- MAIN CONTENT -->
  <main class="main">

    <!-- RECENT POSTS -->
    <div class="section-header">
      <h2 class="section-title">Recent Posts</h2>
      <a href="/posts" class="section-link">All posts →</a>
    </div>

    {recentWithImages.length > 0 ? (
        <div class="grid-3">
            {recentWithImages.map(({ post, coverImage }) => {
                const meta = categoryMeta[post.collection] ?? { label: post.collection, abbr: 'POST', colorClass: 'tag-c', dotClass: 'dot-c' };
                return (
                    <a href={`/${post.collection}/${post.id}`} class="article-card">
                    <div class={`article-card-img img-${post.collection}`}>
                        {coverImage && (
                        <Image
                            src={coverImage}
                            alt={post.data.title}
                            class="article-img"
                            loading="lazy"
                        />
                        )}
                        <div class="img-label">{meta.abbr}</div>
                        <div class={`img-dot ${meta.dotClass}`}></div>
                    </div>
                    <div class="article-card-body">
                        <div class="article-tags">
                        <span class={`tag ${meta.colorClass}`}>{meta.label}</span>
                        </div>
                        <h3 class="article-title">{post.data.title}</h3>
                        <p class="article-excerpt">{post.data.description}</p>
                        <div class="article-footer">
                        <span>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                        <span>5 min</span>
                        </div>
                    </div>
                    </a>
                );
            })}
        </div>
        ) : (
        <div class="empty-state">No posts yet — check back soon.</div>
    )}

    <!-- BEHIND THE BUILD + SIDEBAR -->
    <div class="section-header" style="margin-top: 3rem;">
      <h2 class="section-title">Behind the Build</h2>
      <a href="/behind-the-build" class="section-link">All Builds →</a>
    </div>

    <div class="split">
      <div class="long-reads">
        {behindTheBuild.length > 0 ? behindTheBuild.map((post, i) => {
            const sub = subMeta[post.data.subcategory ?? ''] ?? { label: 'Behind the Build', colorClass: 'tag-a' };
            return (
                <a href={`/behind-the-build/${post.id}`} class="long-read">
                <div class="long-num">0{i + 1}</div>
                <div class="lr-content">
                    <div class="article-tags" style="margin-bottom: 0.5rem;">
                    <span class={`tag ${sub.colorClass}`}>{sub.label}</span>
                    </div>
                    <h3 class="lr-title">{post.data.title}</h3>
                    <div class="lr-meta">
                    <span>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                    <span>8 min read</span>
                    </div>
                    <p class="lr-excerpt">{post.data.description}</p>
                </div>
                </a>
            );
        }) : (
            <div class="empty-state">No build posts yet.</div>
        )}
      </div>

      <aside class="sidebar">
        <div class="sidebar-widget">
          <div class="widget-title">Browse topics</div>
          <div class="cat-pill-list">
            <a href="/for-business" class="cat-pill">
                <span class="cat-pill-name"><span class="cpd dot-c"></span>For Business</span>
                <span class="cat-pill-count">{collectionCounts['for-business']}</span>
            </a>
            <a href="/design" class="cat-pill">
                <span class="cat-pill-name"><span class="cpd dot-m"></span>Design</span>
                <span class="cat-pill-count">{collectionCounts['design']}</span>
            </a>
            <a href="/portfolios" class="cat-pill">
                <span class="cat-pill-name"><span class="cpd dot-g"></span>Portfolios</span>
                <span class="cat-pill-count">{collectionCounts['portfolios']}</span>
            </a>
            <a href="/behind-the-build" class="cat-pill">
                <span class="cat-pill-name"><span class="cpd dot-a"></span>Behind the Build</span>
                <span class="cat-pill-count">{collectionCounts['behind-the-build']}</span>
            </a>
            <a href="/guides" class="cat-pill">
                <span class="cat-pill-name"><span class="cpd dot-w"></span>Guides</span>
                <span class="cat-pill-count">{collectionCounts['guides']}</span>
            </a>
            <a href="/case-studies" class="cat-pill">
                <span class="cat-pill-name"><span class="cpd dot-c"></span>Case Studies</span>
                <span class="cat-pill-count">{collectionCounts['case-studies']}</span>
            </a>
          </div>
        </div>
      </aside>
    </div>

  </main>

  <!-- SKYZER BAND -->
    <div class="skyzer-band">
        <div class="sky-left">
            <div class="sky-icon">SN</div>
            <div class="sky-text">
                <p>This blog is brought to you by Skyzer Networks</p>
                <span>Web design for small businesses and portfolios</span>
            </div>
        </div>
        <a href="https://skyzernetworks.com" class="sky-link">Visit skyzernetworks.com →</a>
    </div>

    <!-- CASE STUDIES BAND -->
    <section class="cs-band">
    <div class="cs-stripe"></div>
    <div class="cs-inner">
        <div class="cs-header">
        <div class="cs-eyebrow">Deep Research</div>
        <h2 class="cs-title">Case Studies</h2>
        <p class="cs-sub">Long-form research and in-depth analysis on what actually works.</p>
        <a href="/case-studies" class="section-link" style="margin-top: 0.5rem; display:inline-block;">See all case studies →</a>
        </div>
        {caseStudies.length > 0 ? (
        <div class="cs-list">
            {caseStudies.map((post, i) => {
            const sub = subMeta[post.data.subcategory ?? ''] ?? { label: 'Case Study', colorClass: 'tag-c' };
            return (
                <a href={`/case-studies/${post.id}`} class="cs-row">
                <div class="cs-num">{String(i + 1).padStart(2, '0')}</div>
                <div class="cs-body">
                    <div class="article-tags" style="margin-bottom: 0.4rem;">
                    <span class={`tag ${sub.colorClass}`}>{sub.label}</span>
                    </div>
                    <h3 class="cs-row-title">{post.data.title}</h3>
                    <p class="cs-row-excerpt">{post.data.description}</p>
                    <div class="lr-meta">
                    <span>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                    <span>Long read</span>
                    </div>
                </div>
                <div class="cs-arrow">→</div>
                </a>
            );
            })}
        </div>
        ) : (
        <div class="empty-state" style="color: rgba(245,243,239,0.4);">No case studies yet — check back soon.</div>
        )}
    </div>
    </section>
</Layout>

<style>

/* ── HERO ── */
.hero {
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
    padding-top: clamp(2rem, 10vw + 2rem, 5rem);
    min-height: 100svh;
}

.hero-stripe {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
        -45deg,
        transparent, transparent 38px,
        rgba(0, 200, 255, 0.267) 38px,
        rgba(174, 0, 255, 0.24) 39px
    );
    pointer-events: none;
}

.hero-left {
    padding: var(--space-2xl) var(--space-lg);
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
}

.hero-eyebrow {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    color: var(--blue);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
}

.hero-eyebrow::before {
    content: '';
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--blue);
}

.hero-title {
    font-family: var(--font-title);
    font-size: var(--text-5xl);
    line-height: 0.95;
    letter-spacing: 1px;
    margin-bottom: var(--space-lg);
    color: var(--white);
}

.hero-gradient {
    display: block;
    background: linear-gradient(90deg, var(--blue), var(--purple));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.hero-body {
    color: rgba(245,243,239,0.6);
    font-size: var(--text-sm);
    font-weight: 300;
    max-width: 480px;
    margin-bottom: 2rem;
    line-height: 1.75;
}

.hero-ctas {
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
}

.btn-outline {
    background: transparent;
    border: 1px solid var(--blue);
    color: var(--blue);
    padding: var(--space-sm) var(--space-lg);
    border-radius: 4px;
    font-size: var(--text-xs);
    font-family: var(--font-sub);
    cursor: pointer;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    text-decoration: none;
    transition: background 0.2s, color 0.2s;
    display: inline-block;
}

.btn-outline:hover { background: var(--blue); color: #000; }

.btn-ghost {
    color: var(--muted);
    font-size: var(--text-sm);
    cursor: pointer;
    background: none;
    border: none;
    font-family: var(--font-sub);
    transition: color 0.2s;
    text-decoration: none;
}

.btn-ghost:hover { color: var(--white); }

.hero-right {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 1.25rem 3rem;
}

/* Featured Card */
.featured-card {
    background: var(--card-bg);
    border: 0.5px solid rgba(0,200,255,0.2);
    border-radius: 8px;
    overflow: hidden;
    width: 100%;
    max-width: 480px;
}

.featured-card-header {
    background: #0d1520;
    padding: 2rem 1.5rem 1.5rem;
}

.feat-badge {
    background: rgba(0,200,255,0.1);
    border: 0.5px solid rgba(0,200,255,0.3);
    color: var(--blue);
    font-family: var(--font-display);
    font-size: var(--text-xs);
    letter-spacing: 1.5px;
    padding: 4px 10px;
    border-radius: 2px;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 1rem;
}

.featured-card-title {
    font-family: var(--font-sub);
    font-size: var(--text-lg);
    letter-spacing: 1px;
    line-height: 1.1;
    margin-bottom: 0.75rem;
}

.featured-card-meta {
    display: flex;
    gap: 12px;
    font-size: var(--text-xs);
    color: var(--muted);
    font-family: var(--font-display);
}

.featured-card-body { padding: 1.5rem; }

.featured-card-body p {
    font-size: var(--text-sm);
    color: rgba(245,243,239,0.55);
    margin-bottom: var(--space-md);
    line-height: 1.65;
    font-weight: 300;
}

.read-more {
    font-size: var(--text-xs);
    color: var(--blue);
    text-decoration: none;
    font-family: var(--font-display);
    letter-spacing: 0.3px;
}

.read-more::after { content: ' →'; }

/* ── CATEGORY STRIP ── */
.cat-strip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
    background: var(--mid);
}

.cat-item {
    padding: 1.1rem 1.25rem;
    border-right: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
    cursor: pointer;
    transition: background 0.15s;
    text-decoration: none;
}

.cat-item:hover { background: rgba(255,255,255,0.03); }

.cat-name {
    font-family: var(--font-title);
    font-size: var(--text-md);
    letter-spacing: 1.5px;
    color: var(--white);
    margin-bottom: 3px;
}

.cat-desc {
    font-size: var(--text-sm);
    color: var(--muted);
    line-height: 1.4;
    font-weight: 400;
}

/* ── MAIN ── */
.main {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 1.25rem;
}

.section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin: 3rem 0 1.5rem;
    border-bottom: 0.5px solid var(--border);
    padding-bottom: 1rem;
}

.section-title {
    font-family: var(--font-title);
    font-size: var(--text-2xl);
    letter-spacing: 2px;
}

.section-link {
    font-size: var(--text-xs);
    color: var(--muted);
    font-family: var(--font-display);
    text-decoration: none;
}

.section-link:hover { color: var(--blue); }

.empty-state {
    font-size: var(--text-sm);
    color: var(--muted);
    font-family: var(--font-display);
    padding: 2rem 0;
}

/* Article Grid */
.grid-3 {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
}

.article-card {
    background: var(--card-bg);
    border: 0.5px solid var(--border);
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    transition: border-color 0.2s;
    text-decoration: none;
    display: block;
}

.article-card:hover { border-color: var(--border-hover); }

.article-card-img {
    height: 150px;
    position: relative;
    overflow: hidden;
}

.article-card-img {
  position: relative;
  overflow: hidden;
}

.article-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.img-for-business  { background: #0e1a10; }
.img-design        { background: #1a0e1a; }
.img-portfolios    { background: #0e1018; }
.img-behind-the-build { background: #1a150a; }
.img-guides        { background: #0a1a18; }
.img-case-studies  { background: #1a0a10; }

.img-label {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-title);
    font-size: var(--text-4xl);
    letter-spacing: 3px;
    opacity: 0.1;
    color: var(--white);
    user-select: none;
}

.img-dot {
    position: absolute;
    top: 14px;
    right: 14px;
    width: 6px;
    height: 6px;
    border-radius: 50%;
}

.dot-c { background: var(--blue); }
.dot-m { background: var(--purple); }
.dot-g { background: #00ff88; }
.dot-a { background: #ffaa00; }
.dot-w { background: #c8c8c8; }

.article-card-body { padding: 1rem 1.1rem; }

.article-tags {
    display: flex;
    gap: 5px;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
}

.tag {
    background: rgba(255,255,255,0.05);
    border: 0.5px solid var(--border);
    color: var(--muted);
    font-size: var(--text-xs);
    font-family: var(--font-display);
    padding: 3px 8px;
    border-radius: 2px;
    letter-spacing: 0.5px;
    text-transform: uppercase;
}

.tag-c { border-color: rgba(0,200,255,0.3);   color: var(--blue);    background: rgba(0,200,255,0.05); }
.tag-m { border-color: rgba(204,0,255,0.3);   color: #cc66ff;        background: rgba(204,0,255,0.05); }
.tag-g { border-color: rgba(0,255,136,0.3);   color: #00dd77;        background: rgba(0,255,136,0.05); }
.tag-a { border-color: rgba(255,170,0,0.3);   color: #ffaa00;        background: rgba(255,170,0,0.05); }
.tag-w { border-color: rgba(200,200,200,0.2); color: #c8c8c8;        background: rgba(200,200,200,0.04); }

.article-title {
    font-size: var(--text-md);
    font-family: var(--font-sub);
    font-weight: 500;
    line-height: 1.4;
    margin-bottom: 0.5rem;
    color: var(--white);
}

.article-excerpt {
    font-size: var(--text-sm);
    color: rgba(245,243,239,0.48);
    font-weight: 300;
    line-height: 1.6;
