---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const collections = [
  "for-business",
  "design",
  "portfolios",
  "behind-the-build",
  "guides",
  "case-studies",
] as const;

const allPosts = (
  await Promise.all(
    collections.map((col) =>
      getCollection(col)
        .then((entries) =>
          entries
            .filter((e) => !e.data.draft)
            .map((e) => ({
              id:          e.id,
              collection:  col,
              title:       e.data.title,
              description: e.data.description,
              tags:        e.data.tags ?? [],
              pubDate:     e.data.pubDate.toLocaleDateString("en-US", {
                month: "short", day: "numeric", year: "numeric",
              }),
              url: `/${col}/${e.id}`,
            }))
        )
        .catch(() => [])
    )
  )
).flat();

const categoryMeta: Record<string, { label: string; colorClass: string }> = {
  "for-business":     { label: "For Business",    colorClass: "tag-c" },
  "design":           { label: "Design",           colorClass: "tag-m" },
  "portfolios":       { label: "Portfolios",       colorClass: "tag-g" },
  "behind-the-build": { label: "Behind the Build", colorClass: "tag-a" },
  "guides":           { label: "Guides",           colorClass: "tag-w" },
  "case-studies":     { label: "Case Study",       colorClass: "tag-c" },
};

const searchIndex = JSON.stringify(allPosts);
---

<Layout
  title="Search | 24 Hour Journey"
  description="Search across all articles on 24 Hour Journey by title, topic, or keyword."
  url="https://24hourjourney.blog/search"
  image_preview="/icons/preview.png"
  type="website"
>
  <div class="search-page">

    <header class="search-header">
      <div class="search-header-inner">
        <div class="search-eyebrow">Search</div>
        <h1 class="search-title">Find an article</h1>

        <div class="search-bar-wrap">
          <input
            id="search-input"
            type="text"
            class="search-bar"
            placeholder="Search by title, topic, or keyword…"
            autocomplete="off"
            spellcheck="false"
          />
          <svg class="search-bar-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/>
          </svg>
          <button id="search-clear" class="search-clear" aria-label="Clear search" style="display:none">✕</button>
        </div>

        <div id="search-status" class="search-status"></div>
      </div>
    </header>

    <main class="search-main">
      <div id="results-grid" class="results-grid"></div>
      <div id="empty-state" class="empty-state" style="display:none">
        <div class="empty-icon">⌕</div>
        <p class="empty-title">No results found</p>
        <p class="empty-sub">Try a different keyword or browse a category below.</p>
        <div class="empty-cats">
          {Object.entries(categoryMeta).map(([col, meta]) => (
            <a href={`/${col}`} class={`tag ${meta.colorClass}`}>{meta.label}</a>
          ))}
        </div>
      </div>
      <div id="idle-state" class="idle-state">
        <p class="idle-prompt">Start typing to search across all posts.</p>
        <div class="idle-cats">
          <p class="idle-label">Or browse by category</p>
          <div class="idle-cat-grid">
            {Object.entries(categoryMeta).map(([col, meta]) => (
              <a href={`/${col}`} class={`cat-pill-link ${meta.colorClass}`}>{meta.label}</a>
            ))}
          </div>
        </div>
      </div>
    </main>

  </div>
</Layout>

<script define:vars={{ searchIndex }}>
  const posts = JSON.parse(searchIndex);

  const categoryMeta = {
    "for-business":     { label: "For Business",    colorClass: "tag-c" },
    "design":           { label: "Design",           colorClass: "tag-m" },
    "portfolios":       { label: "Portfolios",       colorClass: "tag-g" },
    "behind-the-build": { label: "Behind the Build", colorClass: "tag-a" },
    "guides":           { label: "Guides",           colorClass: "tag-w" },
    "case-studies":     { label: "Case Study",       colorClass: "tag-c" },
  };

  const input    = document.getElementById("search-input");
  const clearBtn = document.getElementById("search-clear");
  const grid     = document.getElementById("results-grid");
  const emptyEl  = document.getElementById("empty-state");
  const idleEl   = document.getElementById("idle-state");
  const statusEl = document.getElementById("search-status");

  const STOP = new Set(["a","an","the","and","or","of","to","in","is","it","with","for","on","at","by","as","be","was","that","this","are","from","too","not","but","so","do","my","we","i"]);

  function tokenize(str) {
    return str.toLowerCase().split(/\s+/).filter(w => w.length > 1 && !STOP.has(w));
  }

  function highlight(text, words) {
    if (!words.length) return text;
    const pattern = words.map(w => w.replace(/[.*+?^${}()|[\]\\]/g, "\\$&")).join("|");
    return text.replace(new RegExp(`(${pattern})`, "gi"), "<mark style='background:rgba(0,200,255,0.18);color:#00c8ff;border-radius:2px;padding:0 2px;'>$1</mark>");
  }

  function scorePost(post, words) {
    if (!words.length) return 0;
    const title = post.title.toLowerCase();
    const desc  = post.description.toLowerCase();
    const tags  = (post.tags || []).join(" ").toLowerCase();
    let score = 0;
    for (const w of words) {
      if (title.includes(w)) score += 10;
      if (desc.includes(w))  score += 4;
      if (tags.includes(w))  score += 6;
    }
    return score;
  }

  function renderCard(post, words) {
    const meta = categoryMeta[post.collection] || { label: post.collection, colorClass: "tag-c" };
    const titleH = highlight(post.title, words);
    const descH  = highlight(post.description, words);
    const tagsH  = (post.tags || [])
      .map(t => `<span class="tag tag-plain">${highlight("#" + t, words)}</span>`)
      .join("");
    return `
      <a href="${post.url}" class="result-card">
        <div class="result-card-top">
          <span class="tag ${meta.colorClass}">${meta.label}</span>
          <span class="result-date">${post.pubDate}</span>
        </div>
        <h2 class="result-title">${titleH}</h2>
        <p class="result-desc">${descH}</p>
        ${post.tags && post.tags.length ? `<div class="result-tags">${tagsH}</div>` : ""}
      </a>
    `;
  }

  function search(raw) {
    const query = raw.trim();
    clearBtn.style.display = query ? "flex" : "none";

    if (!query) {
      grid.innerHTML        = "";
      emptyEl.style.display = "none";
      idleEl.style.display  = "block";
      statusEl.textContent  = "";
      return;
    }

    idleEl.style.display = "none";
    const words = tokenize(query);

    const scored = posts
      .map(p => ({ post: p, score: scorePost(p, words) }))
      .filter(({ score }) => score > 0)
      .sort((a, b) => b.score - a.score);

    statusEl.textContent = scored.length
      ? `${scored.length} result${scored.length === 1 ? "" : "s"} for "${query}"`
      : "";

    if (scored.length === 0) {
      grid.innerHTML        = "";
      emptyEl.style.display = "block";
    } else {
      emptyEl.style.display = "none";
      grid.innerHTML        = scored.map(({ post }) => renderCard(post, words)).join("");
    }
  }

  input.addEventListener("input", (e) => search(e.target.value));

  clearBtn.addEventListener("click", () => {
    input.value = "";
    input.focus();
    search("");
  });

  // Run search immediately if ?q= param present
  const params  = new URLSearchParams(window.location.search);
  const initial = params.get("q") || "";
  if (initial) {
    input.value = initial;
    search(initial);
  }
</script>

<style>
/* ── PAGE ── */
.search-page {
  min-height: 100vh;
}

/* ── HEADER ── */
.search-header {
  position: relative;
  background: var(--mid);
  border-bottom: 0.5px solid var(--border);
  padding: clamp(2.5rem, 8vw, 5rem) 1.25rem 2.5rem;
  overflow: hidden;
  margin-top: var(--space-2xl);
}

.search-header::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    -45deg,
    transparent, transparent 38px,
    rgba(0, 200, 255, 0.04) 38px,
    rgba(174, 0, 255, 0.035) 39px
  );
  pointer-events: none;
}

.search-header-inner {
  position: relative;
  z-index: 1;
  max-width: 720px;
  margin: 0 auto;
}

.search-eyebrow {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--blue);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: var(--space-sm);
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.search-eyebrow::before {
  content: '';
  display: inline-block;
  width: 24px;
  height: 1px;
  background: var(--blue);
}

.search-title {
  font-family: var(--font-title);
  font-size: clamp(1.75rem, 4vw + 1rem, 3rem);
  line-height: 1.05;
  letter-spacing: 0.5px;
  color: var(--white);
  margin-bottom: 1.75rem;
}

/* Search bar */
.search-bar-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.search-bar {
  width: 100%;
  background: var(--card-bg);
  border: 0.5px solid rgba(0,200,255,0.25);
  border-radius: 6px;
  padding: 0.85rem 3rem 0.85rem 2.75rem;
  color: var(--white);
  font-size: var(--text-md);
  font-family: var(--font-sub);
  outline: none;
  transition: border-color 0.2s;
}

.search-bar:focus {
  border-color: var(--blue);
}

.search-bar::placeholder {
  color: var(--muted);
}

.search-bar-icon {
  position: absolute;
  left: 0.85rem;
  color: var(--muted);
  pointer-events: none;
  flex-shrink: 0;
}

.search-clear {
  position: absolute;
  right: 0.85rem;
  background: none;
  border: none;
  color: var(--muted);
  cursor: pointer;
  font-size: var(--text-xs);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4px;
  transition: color 0.15s;
}

.search-clear:hover { color: var(--white); }

.search-status {
  margin-top: 0.85rem;
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
  letter-spacing: 0.5px;
  min-height: 1.2em;
}

/* ── MAIN ── */
.search-main {
  max-width: 720px;
  margin: 0 auto;
  padding: 2.5rem 1.25rem 4rem;
}

/* ── RESULTS ── */
.results-grid {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}

.result-card {
  display: block;
  background: var(--card-bg);
  border: 0.5px solid var(--border);
  border-radius: 6px;
  padding: 1.25rem 1.4rem;
  text-decoration: none;
  transition: border-color 0.2s;
}

.result-card:hover { border-color: var(--border-hover); }

.result-card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.65rem;
  gap: 0.5rem;
  flex-wrap: wrap;
}

.result-date {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
}

.result-title {
  font-family: var(--font-sub);
  font-size: var(--text-lg);
  font-weight: 500;
  color: var(--white);
  line-height: 1.3;
  margin-bottom: 0.5rem;
}

.result-title :global(mark),
.result-desc :global(mark),
.result-tags :global(mark) {
  background: rgba(0,200,255,0.18);
  color: var(--blue);
  border-radius: 2px;
  padding: 0 2px;
}

.result-desc {
  font-size: var(--text-sm);
  color: rgba(245,243,239,0.5);
  font-weight: 300;
  line-height: 1.65;
  margin-bottom: 0.75rem;
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 5px;
}

/* Tags */
.tag {
  background: rgba(255,255,255,0.05);
  border: 0.5px solid var(--border);
  color: var(--muted);
  font-size: var(--text-xs);
  font-family: var(--font-display);
  padding: 3px 9px;
  border-radius: 2px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.tag-plain {
  border-color: rgba(255,255,255,0.08);
  color: rgba(245,243,239,0.35);
  font-size: 10px;
  text-transform: none;
  letter-spacing: 0;
}

.tag-c { border-color: rgba(0,200,255,0.3);   color: var(--blue);  background: rgba(0,200,255,0.06);  }
.tag-m { border-color: rgba(204,0,255,0.3);   color: #cc66ff;      background: rgba(204,0,255,0.06);  }
.tag-g { border-color: rgba(0,255,136,0.3);   color: #00dd77;      background: rgba(0,255,136,0.06);  }
.tag-a { border-color: rgba(255,170,0,0.3);   color: #ffaa00;      background: rgba(255,170,0,0.06);  }
.tag-w { border-color: rgba(200,200,200,0.2); color: #c8c8c8;      background: rgba(200,200,200,0.04);}

/* ── EMPTY STATE ── */
.empty-state {
  text-align: center;
  padding: 4rem 0 2rem;
}

.empty-icon {
  font-size: 3rem;
  opacity: 0.15;
  margin-bottom: 1rem;
  font-family: var(--font-title);
}

.empty-title {
  font-family: var(--font-title);
  font-size: var(--text-xl);
  color: var(--white);
  margin-bottom: 0.5rem;
  letter-spacing: 1px;
}

.empty-sub {
  font-size: var(--text-sm);
  color: var(--muted);
  margin-bottom: 1.5rem;
  font-weight: 300;
}

.empty-cats {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  justify-content: center;
}

.empty-cats .tag {
  cursor: pointer;
  text-decoration: none;
  transition: opacity 0.15s;
}

.empty-cats .tag:hover { opacity: 0.8; }

/* ── IDLE STATE ── */
.idle-state {
  padding: 1rem 0 2rem;
}

.idle-prompt {
  font-size: var(--text-sm);
  color: var(--muted);
  font-family: var(--font-display);
  margin-bottom: 2rem;
}

.idle-label {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
  letter-spacing: 1px;
  text-transform: uppercase;
  margin-bottom: 0.85rem;
}

.idle-cat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.cat-pill-link {
  text-decoration: none;
  padding: 6px 14px;
  border-radius: 4px;
  font-size: var(--text-sm);
  font-family: var(--font-display);
  transition: opacity 0.15s;
  border: 0.5px solid;
}

.cat-pill-link:hover { opacity: 0.75; }

.cat-pill-link.tag-c { border-color: rgba(0,200,255,0.3);   color: var(--blue);  background: rgba(0,200,255,0.06);  }
.cat-pill-link.tag-m { border-color: rgba(204,0,255,0.3);   color: #cc66ff;      background: rgba(204,0,255,0.06);  }
.cat-pill-link.tag-g { border-color: rgba(0,255,136,0.3);   color: #00dd77;      background: rgba(0,255,136,0.06);  }
.cat-pill-link.tag-a { border-color: rgba(255,170,0,0.3);   color: #ffaa00;      background: rgba(255,170,0,0.06);  }
.cat-pill-link.tag-w { border-color: rgba(200,200,200,0.2); color: #c8c8c8;      background: rgba(200,200,200,0.04);}

/* ── MEDIA QUERIES ── */
@media (min-width: 480px) {
  .search-header { padding-left: 1.5rem; padding-right: 1.5rem; }
  .search-main   { padding-left: 1.5rem; padding-right: 1.5rem; }
}

@media (min-width: 768px) {
  .search-header { padding-left: 2rem; padding-right: 2rem; }
  .search-main   { padding-left: 2rem; padding-right: 2rem; }
}

@media (min-width: 1024px) {
  .search-header { padding-left: clamp(2rem, 5vw, 4rem); padding-right: clamp(2rem, 5vw, 4rem); }
  .search-main   { padding-left: clamp(2rem, 5vw, 4rem); padding-right: clamp(2rem, 5vw, 4rem); }
}
</style>