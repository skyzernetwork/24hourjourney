---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getPostImage } from '@/lib/getPostImage';

const allPosts = (await Promise.all([
  getCollection('for-business').catch(() => []),
  getCollection('design').catch(() => []),
  getCollection('portfolios').catch(() => []),
  getCollection('behind-the-build').catch(() => []),
  getCollection('guides').catch(() => []),
  getCollection('case-studies').catch(() => []),
])).flat().filter((p: any) => !p.data.draft);

const sorted = allPosts.sort((a: any, b: any) =>
  new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime()
);

const categoryMeta: Record<string, { label: string; abbr: string; colorClass: string; dotClass: string }> = {
  'for-business':     { label: 'For Business',    abbr: 'BIZ',    colorClass: 'tag-c', dotClass: 'dot-c' },
  'design':           { label: 'Design',           abbr: 'DESIGN', colorClass: 'tag-m', dotClass: 'dot-m' },
  'portfolios':       { label: 'Portfolios',       abbr: 'PORT',   colorClass: 'tag-g', dotClass: 'dot-g' },
  'behind-the-build': { label: 'Behind the Build', abbr: 'BUILD',  colorClass: 'tag-a', dotClass: 'dot-a' },
  'guides':           { label: 'Guides',           abbr: 'GUIDE',  colorClass: 'tag-w', dotClass: 'dot-w' },
  'case-studies':     { label: 'Case Study',       abbr: 'CASE',   colorClass: 'tag-c', dotClass: 'dot-c' },
};

const collections = ['for-business', 'design', 'portfolios', 'behind-the-build', 'guides', 'case-studies'] as const;

const counts = Object.fromEntries(
  await Promise.all(
    collections.map(async (col) => {
      const posts = await getCollection(col as any).catch(() => []);
      return [col, (posts as any[]).filter((p) => !p.data.draft).length];
    })
  )
);

const postsWithImages = await Promise.all(
  sorted.map(async (post: any) => ({
    post,
    coverImage: post.data.cover ? await getPostImage(post.data.cover) : null,
  }))
);
---

<Layout
  title="Posts | 24 Hour Journey"
  description="Read all of our latest articles on building websites, growing online, and making smart tech choices for small businesses and creators."
  url="https://24hourjourney.blog/posts"
  image_preview="/icons/preview.png"
  type="website"
>

  <!-- PAGE HEADER -->
  <div class="ap-header">
    <div class="ap-header-inner">
      <div class="aph-eyebrow">
        <span class="aph-pulse"></span>
        Skyzer Networks Blog
      </div>
      <div class="aph-title-row">
        <h1 class="aph-title">All Posts</h1>
        <div class="aph-total">
          <span class="aph-total-num">{sorted.length}</span>
          <span class="aph-total-label">posts</span>
        </div>
      </div>
      <p class="aph-sub">Everything we've written — sorted newest first.</p>
    </div>
  </div>

  <!-- FILTER BAR -->
  <div class="filter-bar" id="filter-bar">
    <div class="filter-bar-inner">
      <button class="fbtn active" data-filter="all">All <span class="fbtn-count">{sorted.length}</span></button>
      <button class="fbtn" data-filter="for-business">For Business <span class="fbtn-count">{counts['for-business']}</span></button>
      <button class="fbtn" data-filter="design">Design <span class="fbtn-count">{counts['design']}</span></button>
      <button class="fbtn" data-filter="portfolios">Portfolios <span class="fbtn-count">{counts['portfolios']}</span></button>
      <button class="fbtn" data-filter="behind-the-build">Behind the Build <span class="fbtn-count">{counts['behind-the-build']}</span></button>
      <button class="fbtn" data-filter="guides">Guides <span class="fbtn-count">{counts['guides']}</span></button>
      <button class="fbtn" data-filter="case-studies">Case Studies <span class="fbtn-count">{counts['case-studies']}</span></button>
    </div>
  </div>

  <!-- MAIN -->
  <main class="ap-main">
    <div class="ap-inner">

      {sorted.length === 0 ? (
        <div class="ap-empty">
          <div class="ap-empty-icon">[ ]</div>
          <p>No posts yet — check back soon.</p>
        </div>
      ) : (
        <div class="posts-list" id="posts-list">
          {postsWithImages.map(({ post, coverImage }: any, idx: number) => {
            const meta = categoryMeta[post.collection] ?? { label: post.collection, abbr: 'POST', colorClass: 'tag-c', dotClass: 'dot-c' };
            const dateStr = post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
            return (
              <a
                href={`/${post.collection}/${post.id}`}
                class="post-row"
                data-category={post.collection}
              >
                <div class="pr-index">{String(idx + 1).padStart(2, '0')}</div>

                <div class={`pr-thumb img-${post.collection}`}>
                  {coverImage ? (
                    <Image
                      src={coverImage}
                      alt={post.data.title}
                      class="pr-thumb-img"
                      loading="lazy"
                    />
                  ) : (
                    <span class="pr-abbr">{meta.abbr}</span>
                  )}
                  <div class={`pr-dot ${meta.dotClass}`}></div>
                </div>

                <div class="pr-body">
                  <div class="pr-tags">
                    <span class={`tag ${meta.colorClass}`}>{meta.label}</span>
                    {post.data.subcategory && (
                      <span class="tag tag-sub">{post.data.subcategory}</span>
                    )}
                  </div>
                  <h2 class="pr-title">{post.data.title}</h2>
                  <p class="pr-excerpt">{post.data.description}</p>
                </div>

                <div class="pr-meta">
                  <span class="pr-date">{dateStr}</span>
                  <span class="pr-read">5 min</span>
                  <span class="pr-arrow">→</span>
                </div>
              </a>
            );
          })}
        </div>
      )}

      <!-- SIDEBAR -->
      <aside class="ap-sidebar" id="ap-sidebar">

        <div class="sb-widget">
          <div class="sb-widget-title">Categories</div>
          <div class="sb-cat-list">
            <button class="sb-cat sb-cat-active" data-filter="all">
              <span class="sb-cat-label"><span class="sb-dot" style="background: rgba(255,255,255,0.25)"></span>All Posts</span>
              <span class="sb-cat-num">{sorted.length}</span>
            </button>
            <button class="sb-cat" data-filter="for-business">
              <span class="sb-cat-label"><span class="sb-dot dot-c"></span>For Business</span>
              <span class="sb-cat-num">{counts['for-business']}</span>
            </button>
            <button class="sb-cat" data-filter="design">
              <span class="sb-cat-label"><span class="sb-dot dot-m"></span>Design</span>
              <span class="sb-cat-num">{counts['design']}</span>
            </button>
            <button class="sb-cat" data-filter="portfolios">
              <span class="sb-cat-label"><span class="sb-dot dot-g"></span>Portfolios</span>
              <span class="sb-cat-num">{counts['portfolios']}</span>
            </button>
            <button class="sb-cat" data-filter="behind-the-build">
              <span class="sb-cat-label"><span class="sb-dot dot-a"></span>Behind the Build</span>
              <span class="sb-cat-num">{counts['behind-the-build']}</span>
            </button>
            <button class="sb-cat" data-filter="guides">
              <span class="sb-cat-label"><span class="sb-dot dot-w"></span>Guides</span>
              <span class="sb-cat-num">{counts['guides']}</span>
            </button>
            <button class="sb-cat" data-filter="case-studies">
              <span class="sb-cat-label"><span class="sb-dot dot-c"></span>Case Studies</span>
              <span class="sb-cat-num">{counts['case-studies']}</span>
            </button>
          </div>
        </div>

        <div class="sb-widget sb-about">
          <div class="sb-widget-title">About this blog</div>
          <p class="sb-about-text">Written by Michael and Matt at Skyzer Networks — a web agency built for small businesses and creators who deserve a site that actually works.</p>
          <a href="/about" class="sb-about-link">Meet the team →</a>
        </div>

      </aside>

    </div>
  </main>

</Layout>

<script>
  // Filter logic — runs on both the top filter bar and the sidebar
  function initFilters() {
    const allButtons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const rows = document.querySelectorAll<HTMLElement>('.post-row');

    function setFilter(value: string) {
      // Update button active states
      allButtons.forEach(btn => {
        btn.classList.toggle('active', btn.dataset.filter === value);
        btn.classList.toggle('sb-cat-active', btn.dataset.filter === value);
      });

      // Show/hide rows
      rows.forEach(row => {
        const match = value === 'all' || row.dataset.category === value;
        row.style.display = match ? '' : 'none';
      });
    }

    allButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        setFilter(btn.dataset.filter ?? 'all');
      });
    });
  }

  document.addEventListener('DOMContentLoaded', initFilters);
  document.addEventListener('astro:page-load', initFilters);
</script>

<style>

/* ─────────────────────────────────────────
   PAGE HEADER — mobile base
───────────────────────────────────────── */
.ap-header {
  border-bottom: 0.5px solid var(--border);
  background: var(--mid);
  margin-top: var(--space-2xl);
}

.ap-header-inner {
  padding: 2.5rem 1.25rem 2rem;
}

.aph-eyebrow {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
  letter-spacing: 2px;
  text-transform: uppercase;
  margin-bottom: 0.75rem;
  display: flex;
  align-items: center;
  gap: 8px;
}

.aph-pulse {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--blue);
  box-shadow: 0 0 0 0 rgba(0,200,255,0.4);
  animation: pulse 2s infinite;
  flex-shrink: 0;
}

@keyframes pulse {
  0%   { box-shadow: 0 0 0 0 rgba(0,200,255,0.4); }
  70%  { box-shadow: 0 0 0 8px rgba(0,200,255,0); }
  100% { box-shadow: 0 0 0 0 rgba(0,200,255,0); }
}

.aph-title-row {
  display: flex;
  align-items: baseline;
  gap: 1rem;
  margin-bottom: 0.5rem;
}

.aph-title {
  font-family: var(--font-title);
  font-size: var(--text-4xl);
  letter-spacing: 2px;
  color: var(--white);
  line-height: 1;
}

.aph-total {
  display: flex;
  align-items: baseline;
  gap: 5px;
}

.aph-total-num {
  font-family: var(--font-title);
  font-size: var(--text-2xl);
  color: rgba(255,255,255,0.15);
  line-height: 1;
}

.aph-total-label {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
  letter-spacing: 1px;
}

.aph-sub {
  font-size: var(--text-sm);
  color: var(--muted);
  font-weight: 300;
}

/* ─────────────────────────────────────────
   FILTER BAR — mobile base
───────────────────────────────────────── */
.filter-bar {
  border-bottom: 0.5px solid var(--border);
  background: var(--bg);
  position: sticky;
  top: 0;
  z-index: 10;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.filter-bar::-webkit-scrollbar { display: none; }

.filter-bar-inner {
  display: flex;
  gap: 0;
  min-width: max-content;
  padding: 0 1.25rem;
}

.fbtn {
  background: none;
  border: none;
  border-bottom: 2px solid transparent;
  color: var(--muted);
  font-family: var(--font-display);
  font-size: var(--text-xs);
  letter-spacing: 0.5px;
  padding: 0.85rem 1rem;
  cursor: pointer;
  white-space: nowrap;
  transition: color 0.15s, border-color 0.15s;
  display: flex;
  align-items: center;
  gap: 6px;
}

.fbtn:hover { color: var(--white); }

.fbtn.active {
  color: var(--white);
  border-bottom-color: var(--blue);
}

.fbtn-count {
  background: rgba(255,255,255,0.07);
  border-radius: 10px;
  padding: 1px 6px;
  font-size: 10px;
  color: var(--muted);
}

.fbtn.active .fbtn-count {
  background: rgba(0,200,255,0.12);
  color: var(--blue);
}

/* ─────────────────────────────────────────
   MAIN LAYOUT — mobile base
───────────────────────────────────────── */
.ap-main {
  padding: 0 1.25rem 4rem;
}

.ap-inner {
  display: flex;
  flex-direction: column;
  gap: 2.5rem;
  padding-top: 2rem;
}

/* Empty state */
.ap-empty {
  padding: 4rem 0;
  text-align: center;
}

.ap-empty-icon {
  font-family: var(--font-title);
  font-size: var(--text-4xl);
  color: rgba(255,255,255,0.08);
  margin-bottom: 1rem;
  letter-spacing: 4px;
}

.ap-empty p {
  font-size: var(--text-sm);
  color: var(--muted);
  font-family: var(--font-display);
}

/* ─────────────────────────────────────────
   POST ROWS — mobile base
───────────────────────────────────────── */
.posts-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  border: 0.5px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
}

.post-row {
  display: grid;
  grid-template-columns: 40px 64px 1fr;
  gap: 1rem;
  align-items: center;
  padding: 1rem 1.1rem;
  background: var(--card-bg);
  border-bottom: 0.5px solid var(--border);
  text-decoration: none;
  transition: background 0.15s;
  position: relative;
}

.post-row:last-child { border-bottom: none; }
.post-row:hover { background: rgba(255,255,255,0.02); }

/* Index number */
.pr-index {
  font-family: var(--font-title);
  font-size: var(--text-lg);
  color: rgba(255,255,255,0.06);
  line-height: 1;
  text-align: center;
  flex-shrink: 0;
}

/* Thumbnail */
.pr-thumb {
  width: 64px;
  height: 64px;
  border-radius: 6px;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.img-for-business     { background: #0e1a10; }
.img-design           { background: #1a0e1a; }
.img-portfolios       { background: #0e1018; }
.img-behind-the-build { background: #1a150a; }
.img-guides           { background: #0a1a18; }
.img-case-studies     { background: #1a0a10; }

.pr-thumb-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.pr-abbr {
  font-family: var(--font-title);
  font-size: 10px;
  letter-spacing: 1.5px;
  color: rgba(255,255,255,0.12);
  user-select: none;
}

.pr-dot {
  position: absolute;
  top: 6px;
  right: 6px;
  width: 5px;
  height: 5px;
  border-radius: 50%;
}

.dot-c { background: var(--blue); }
.dot-m { background: var(--purple); }
.dot-g { background: #00ff88; }
.dot-a { background: #ffaa00; }
.dot-w { background: #c8c8c8; }

/* Post body */
.pr-body { min-width: 0; }

.pr-tags {
  display: flex;
  gap: 5px;
  margin-bottom: 0.4rem;
  flex-wrap: wrap;
}

.tag {
  background: rgba(255,255,255,0.05);
  border: 0.5px solid var(--border);
  color: var(--muted);
  font-size: var(--text-xs);
  font-family: var(--font-display);
  padding: 2px 7px;
  border-radius: 2px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}

.tag-c   { border-color: rgba(0,200,255,0.3);   color: var(--blue);  background: rgba(0,200,255,0.05); }
.tag-m   { border-color: rgba(204,0,255,0.3);   color: #cc66ff;      background: rgba(204,0,255,0.05); }
.tag-g   { border-color: rgba(0,255,136,0.3);   color: #00dd77;      background: rgba(0,255,136,0.05); }
.tag-a   { border-color: rgba(255,170,0,0.3);   color: #ffaa00;      background: rgba(255,170,0,0.05); }
.tag-w   { border-color: rgba(200,200,200,0.2); color: #c8c8c8;      background: rgba(200,200,200,0.04); }
.tag-sub { font-size: 10px; }

.pr-title {
  font-family: var(--font-sub);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--white);
  line-height: 1.35;
  margin-bottom: 0.3rem;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.pr-excerpt {
  font-size: var(--text-xs);
  color: rgba(245,243,239,0.4);
  font-weight: 300;
  line-height: 1.5;
  display: none; /* shown at larger breakpoints */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* Right meta column: hidden on mobile, shown at larger sizes */
.pr-meta {
  display: none;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
  flex-shrink: 0;
}

.pr-date {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
}

.pr-read {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: rgba(255,255,255,0.2);
}

.pr-arrow {
  font-size: var(--text-sm);
  color: rgba(0,200,255,0.4);
  margin-top: 4px;
  transition: color 0.15s, transform 0.15s;
}

.post-row:hover .pr-arrow { color: var(--blue); transform: translateX(3px); }

/* ─────────────────────────────────────────
   SIDEBAR — mobile base (stacks below)
───────────────────────────────────────── */
.ap-sidebar {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.sb-widget {
  background: var(--card-bg);
  border: 0.5px solid var(--border);
  border-radius: 6px;
  padding: 1.25rem;
}

.sb-widget-title {
  font-family: var(--font-title);
  font-size: var(--text-lg);
  letter-spacing: 1.5px;
  color: var(--white);
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 8px;
}
.sb-widget-title::after {
  content: '';
  flex: 1;
  height: 0.5px;
  background: var(--border);
}

.sb-cat-list {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.sb-cat {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 7px 9px;
  border-radius: 4px;
  cursor: pointer;
  background: none;
  border: none;
  transition: background 0.15s;
  width: 100%;
  text-align: left;
}
.sb-cat:hover { background: rgba(255,255,255,0.04); }
.sb-cat.sb-cat-active { background: rgba(0,200,255,0.06); }

.sb-cat-label {
  font-size: var(--text-sm);
  color: var(--white);
  display: flex;
  align-items: center;
  gap: 8px;
}

.sb-cat-num {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
}

.sb-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  flex-shrink: 0;
  display: inline-block;
}

.sb-about-text {
  font-size: var(--text-sm);
  color: rgba(245,243,239,0.5);
  font-weight: 300;
  line-height: 1.65;
  margin-bottom: 1rem;
}

.sb-about-link {
  font-size: var(--text-xs);
  color: var(--blue);
  text-decoration: none;
  font-family: var(--font-display);
  letter-spacing: 0.3px;
}
.sb-about-link:hover { text-decoration: underline; }

/* ─────────────────────────────────────────
   sm — large phones (480px+)
───────────────────────────────────────── */
@media (min-width: 480px) {
  .post-row {
    grid-template-columns: 40px 72px 1fr;
  }

  .pr-thumb {
    width: 72px;
    height: 72px;
  }

  .pr-title {
    font-size: var(--text-md);
  }
}

/* ─────────────────────────────────────────
   md — tablets (768px+)
───────────────────────────────────────── */
@media (min-width: 768px) {
  .ap-header-inner {
    padding: 3rem 2rem 2.5rem;
  }

  .filter-bar-inner {
    padding: 0 2rem;
  }

  .ap-main {
    padding: 0 2rem 4rem;
  }

  .post-row {
    grid-template-columns: 48px 80px 1fr auto;
    padding: 1.1rem 1.25rem;
  }

  .pr-thumb {
    width: 80px;
    height: 80px;
  }

  .pr-excerpt {
    display: block;
  }

  .pr-meta {
    display: flex;
  }

  .pr-title {
    white-space: normal;
    overflow: visible;
    text-overflow: clip;
  }
}

/* ─────────────────────────────────────────
   lg — laptops (1024px+)
───────────────────────────────────────── */
@media (min-width: 1024px) {
  .ap-header-inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 3rem 2.5rem 2.5rem;
  }

  .filter-bar-inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 2.5rem;
    min-width: 0;
  }

  .filter-bar {
    overflow-x: visible;
  }

  .ap-main {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 2.5rem 5rem;
  }

  .ap-inner {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3rem;
    align-items: start;
  }

  /* Sidebar sticks while scrolling the list */
  .ap-sidebar {
    position: sticky;
    top: 56px; /* below the sticky filter bar */
  }

  .post-row {
    grid-template-columns: 48px 88px 1fr auto;
  }

  .pr-thumb {
    width: 88px;
    height: 88px;
  }

  .pr-index {
    font-size: var(--text-xl);
  }
}

/* ─────────────────────────────────────────
   xl — standard desktops (1280px+)
───────────────────────────────────────── */
@media (min-width: 1280px) {
  .ap-header-inner,
  .ap-main {
    padding-left: 3rem;
    padding-right: 3rem;
  }

  .filter-bar-inner {
    padding-left: 3rem;
    padding-right: 3rem;
  }

  .ap-inner {
    grid-template-columns: 1fr 300px;
    gap: 3.5rem;
  }

  .post-row {
    grid-template-columns: 52px 96px 1fr auto;
    padding: 1.25rem 1.5rem;
  }

  .pr-thumb {
    width: 96px;
    height: 96px;
  }
}
</style>