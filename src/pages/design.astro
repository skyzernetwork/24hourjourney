---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getPostImage } from '@/lib/getPostImage';

const allPosts = (await getCollection('design').catch(() => []))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const featured = allPosts.find(p => p.data.featured) ?? allPosts[0];
const rest = allPosts.filter(p => p !== featured);

const postsWithImages = await Promise.all(
  allPosts.map(async (post) => ({
    post,
    coverImage: post.data.cover ? await getPostImage(post.data.cover) : null,
  }))
);

const featuredData = postsWithImages.find(({ post }) => post === featured);
const restWithImages = postsWithImages.filter(({ post }) => post !== featured);

const subMeta: Record<string, { label: string; colorClass: string }> = {
  'design':    { label: 'Design',    colorClass: 'tag-m' },
  'branding':  { label: 'Branding',  colorClass: 'tag-a' },
  'redesign':  { label: 'Redesign',  colorClass: 'tag-a' },
  'guide':     { label: 'Guide',     colorClass: 'tag-w' },
};
---

<Layout
  title="Design | 24 Hour Journey"
  description="What separates a forgettable site from one people actually remember — and how to build the latter."
  url="https://24hourjourney.blog/design"
  image_preview="/icons/preview.png"
  type="website"
>
  <!-- PAGE HEADER -->
  <header class="page-header">
    <div class="header-bg"></div>
    <div class="header-inner">
      <div class="breadcrumb"><a href="/">Home</a><span>/</span><span>Design</span></div>
      <div class="header-tag">DESIGN</div>
      <h1 class="header-title">Look great.<br/><span class="accent-text">Feel intentional.</span></h1>
      <p class="header-desc">What separates a forgettable site from one people actually remember — and how to build the latter.</p>
      <div class="header-stat">
        <span class="stat-num">{allPosts.length}</span>
        <span class="stat-label">articles</span>
      </div>
    </div>
  </header>

  <main class="page-main">

    <!-- MASONRY-STYLE LIST: featured large, rest in rows -->
    {allPosts.length === 0 && (
      <div class="empty-state">No posts yet — check back soon.</div>
    )}

    {featured && featuredData && (
      <section class="featured-section">
        <a href={`/design/${featured.id}`} class="featured-post">
          <div class="fp-img">
            {featuredData.coverImage ? (
              <Image src={featuredData.coverImage} alt={featured.data.title} class="fp-cover" />
            ) : (
              <div class="fp-img-placeholder"><span>DESIGN</span></div>
            )}
            <div class="fp-overlay"></div>
            <div class="fp-badge">Featured</div>
          </div>
          <div class="fp-body">
            <div class="fp-sub">
              {featured.data.subcategory && (
                <span class={`tag ${subMeta[featured.data.subcategory]?.colorClass ?? 'tag-m'}`}>
                  {subMeta[featured.data.subcategory]?.label ?? featured.data.subcategory}
                </span>
              )}
            </div>
            <h2 class="fp-title">{featured.data.title}</h2>
            <p class="fp-excerpt">{featured.data.description}</p>
            <div class="fp-footer">
              <span class="fp-date">{featured.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              <span class="fp-read">Read article →</span>
            </div>
          </div>
        </a>
      </section>
    )}

    {restWithImages.length > 0 && (
      <section class="articles-section">
        <div class="section-label">All Articles</div>
        <!-- Alternating row layout: odd = card with left image, even = text only list item -->
        <div class="articles-list">
          {restWithImages.map(({ post, coverImage }, i) => {
            const sub = subMeta[post.data.subcategory ?? ''] ?? { label: 'Design', colorClass: 'tag-m' };
            return (
              <a href={`/design/${post.id}`} class="list-item">
                <div class="li-num">
                  {String(i + 1).padStart(2, '0')}
                </div>
                <div class="li-img">
                  {coverImage ? (
                    <Image src={coverImage} alt={post.data.title} class="li-cover" />
                  ) : (
                    <div class="li-placeholder"><span>D</span></div>
                  )}
                </div>
                <div class="li-body">
                  <span class={`tag ${sub.colorClass}`}>{sub.label}</span>
                  <h3 class="li-title">{post.data.title}</h3>
                  <p class="li-excerpt">{post.data.description}</p>
                  <div class="li-footer">
                    <span>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                    <span>5 min read</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

  </main>
</Layout>

<style>
/* ── PAGE HEADER ── */
.page-header {
  position: relative;
  overflow: hidden;
  padding: 4rem 1.25rem 3rem;
  margin-top: var(--space-2xl);
  border-bottom: 0.5px solid var(--border);
}

.header-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 50% 100% at 90% 50%, rgba(204,0,255,0.07) 0%, transparent 70%),
    radial-gradient(circle at 10% 80%, rgba(0,200,255,0.04) 0%, transparent 50%);
  pointer-events: none;
}

.header-inner {
  position: relative;
  z-index: 1;
  max-width: 1160px;
  margin: 0 auto;
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
  margin-bottom: 1.5rem;
}

.breadcrumb a { color: var(--muted); text-decoration: none; }
.breadcrumb a:hover { color: #cc66ff; }
.breadcrumb span:last-child { color: #cc66ff; }

.header-tag {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  letter-spacing: 3px;
  color: #cc66ff;
  text-transform: uppercase;
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 10px;
}

.header-tag::before {
  content: '';
  width: 28px;
  height: 1px;
  background: #cc66ff;
}

.header-title {
  font-family: var(--font-title);
  font-size: var(--text-4xl);
  line-height: 1;
  letter-spacing: 1px;
  color: var(--white);
  margin-bottom: 1rem;
}

.accent-text {
  background: linear-gradient(90deg, #cc66ff, var(--blue));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.header-desc {
  font-size: var(--text-sm);
  color: rgba(245,243,239,0.55);
  max-width: 480px;
  line-height: 1.7;
  font-weight: 300;
  margin-bottom: 1.5rem;
}

.header-stat {
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.stat-num {
  font-family: var(--font-title);
  font-size: var(--text-3xl);
  color: #cc66ff;
  line-height: 1;
}

.stat-label {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
  letter-spacing: 1px;
  text-transform: uppercase;
}

/* ── MAIN ── */
.page-main {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 1.25rem 4rem;
}

.empty-state {
  font-size: var(--text-sm);
  color: var(--muted);
  font-family: var(--font-display);
  padding: 4rem 0;
  text-align: center;
}

/* ── FEATURED ── */
.featured-section {
  padding: 2.5rem 0 2rem;
  border-bottom: 0.5px solid var(--border);
  margin-bottom: 2.5rem;
}

.featured-post {
  display: flex;
  flex-direction: column;
  background: var(--card-bg);
  border: 0.5px solid rgba(204,0,255,0.2);
  border-radius: 8px;
  overflow: hidden;
  text-decoration: none;
  transition: border-color 0.2s;
}

.featured-post:hover { border-color: rgba(204,0,255,0.5); }

.fp-img {
  position: relative;
  height: 240px;
  background: #1a0d1a;
  overflow: hidden;
}

.fp-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.fp-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, rgba(26,13,26,0.5), transparent);
}

.fp-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1a0d1a, #120a20);
}

.fp-img-placeholder span {
  font-family: var(--font-title);
  font-size: var(--text-4xl);
  letter-spacing: 4px;
  color: rgba(204,0,255,0.1);
}

.fp-badge {
  position: absolute;
  top: 14px;
  left: 14px;
  background: rgba(204,0,255,0.1);
  border: 0.5px solid rgba(204,0,255,0.35);
  color: #cc66ff;
  font-family: var(--font-display);
  font-size: var(--text-xs);
  letter-spacing: 1.5px;
  padding: 4px 10px;
  border-radius: 2px;
  text-transform: uppercase;
}

.fp-body {
  padding: 1.5rem;
}

.fp-sub { margin-bottom: 0.75rem; }

.fp-title {
  font-family: var(--font-sub);
  font-size: var(--text-2xl);
  line-height: 1.2;
  color: var(--white);
  margin-bottom: 0.75rem;
  letter-spacing: 0.5px;
}

.fp-excerpt {
  font-size: var(--text-sm);
  color: rgba(245,243,239,0.55);
  font-weight: 300;
  line-height: 1.7;
  margin-bottom: 1.25rem;
}

.fp-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 0.5px solid var(--border);
  padding-top: 1rem;
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
}

.fp-read { color: #cc66ff; }

/* ── LIST LAYOUT ── */
.section-label {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 1.25rem;
  display: flex;
  align-items: center;
  gap: 10px;
}

.section-label::after {
  content: '';
  flex: 1;
  height: 0.5px;
  background: var(--border);
}

.articles-list {
  display: flex;
  flex-direction: column;
  gap: 1px;
  border: 0.5px solid var(--border);
  border-radius: 6px;
  overflow: hidden;
}

.list-item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.1rem 1.25rem;
  background: var(--card-bg);
  border-bottom: 0.5px solid var(--border);
  text-decoration: none;
  transition: background 0.15s;
}

.list-item:last-child { border-bottom: none; }
.list-item:hover { background: rgba(204,0,255,0.03); }

.li-num {
  font-family: var(--font-title);
  font-size: var(--text-lg);
  color: rgba(255,255,255,0.07);
  line-height: 1;
  width: 28px;
  flex-shrink: 0;
  padding-top: 2px;
}

.li-img {
  width: 80px;
  height: 60px;
  border-radius: 4px;
  overflow: hidden;
  flex-shrink: 0;
  background: #1a0d1a;
}

.li-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.li-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.li-placeholder span {
  font-family: var(--font-title);
  font-size: var(--text-lg);
  color: rgba(204,0,255,0.1);
}

.li-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.li-title {
  font-family: var(--font-sub);
  font-size: var(--text-md);
  color: var(--white);
  font-weight: 500;
  line-height: 1.35;
}

.li-excerpt {
  font-size: var(--text-sm);
  color: rgba(245,243,239,0.45);
  font-weight: 300;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.li-footer {
  display: flex;
  gap: 10px;
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
}

/* Tags */
.tag {
  background: rgba(255,255,255,0.05);
  border: 0.5px solid var(--border);
  color: var(--muted);
  font-size: var(--text-xs);
  font-family: var(--font-display);
  padding: 3px 8px;
  border-radius: 2px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  display: inline-block;
}

.tag-c { border-color: rgba(0,200,255,0.3);   color: var(--blue);    background: rgba(0,200,255,0.05); }
.tag-m { border-color: rgba(204,0,255,0.3);   color: #cc66ff;        background: rgba(204,0,255,0.05); }
.tag-g { border-color: rgba(0,255,136,0.3);   color: #00dd77;        background: rgba(0,255,136,0.05); }
.tag-a { border-color: rgba(255,170,0,0.3);   color: #ffaa00;        background: rgba(255,170,0,0.05); }
.tag-w { border-color: rgba(200,200,200,0.2); color: #c8c8c8;        background: rgba(200,200,200,0.04); }

/* ── MEDIA QUERIES ── */

/* sm — large phones (480px+) */
@media (min-width: 480px) {
  .li-img {
    width: 100px;
    height: 72px;
  }
}

/* md — tablets (768px+) */
@media (min-width: 768px) {
  .page-header {
    padding: 5rem 2rem 3.5rem;
  }

  .header-title {
    font-size: var(--text-5xl);
  }

  .page-main {
    padding: 0 2rem 4rem;
  }

  .featured-post {
    flex-direction: row;
  }

  .fp-img {
    width: 400px;
    height: auto;
    flex-shrink: 0;
  }

  .fp-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .fp-title {
    font-size: var(--text-3xl);
  }

  .li-img {
    width: 120px;
    height: 85px;
  }

  .li-excerpt {
    -webkit-line-clamp: 2;
  }
}

/* lg — laptops (1024px+) */
@media (min-width: 1024px) {
  .list-item {
    gap: 1.5rem;
    padding: 1.25rem 1.5rem;
  }

  .li-img {
    width: 140px;
    height: 95px;
  }
}

/* xl — standard desktops (1280px+) */
@media (min-width: 1280px) {
  .fp-img {
    width: 500px;
  }
}
</style>