---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getPostImage } from '@/lib/getPostImage';

const allPosts = (await getCollection('behind-the-build').catch(() => []))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const featured = allPosts.find(p => p.data.featured) ?? allPosts[0];

const postsWithImages = await Promise.all(
  allPosts.map(async (post) => ({
    post,
    coverImage: post.data.cover ? await getPostImage(post.data.cover) : null,
  }))
);

const featuredData = postsWithImages.find(({ post }) => post === featured);
const restWithImages = postsWithImages.filter(({ post }) => post !== featured);

const subMeta: Record<string, { label: string; colorClass: string }> = {
  'case-study':      { label: 'Case Study',      colorClass: 'tag-c' },
  'portfolio-build': { label: 'Portfolio Build',  colorClass: 'tag-g' },
  'redesign':        { label: 'Redesign',         colorClass: 'tag-a' },
  'branding':        { label: 'Branding',         colorClass: 'tag-a' },
  'ecommerce':       { label: 'E-Commerce',       colorClass: 'tag-w' },
};
---

<Layout
  title="Behind the Build | 24 Hour Journey"
  description="We pull back the curtain on how Skyzer Networks builds websites — the choices, the process, and what actually worked."
  url="https://24hourjourney.blog/behind-the-build"
  image_preview="/icons/preview.png"
  type="website"
>
  <!-- PAGE HEADER -->
  <header class="page-header">
    <div class="header-bg"></div>
    <div class="header-inner">
      <div class="breadcrumb"><a href="/">Home</a><span>/</span><span>Behind the Build</span></div>
      <div class="header-tag">BEHIND THE BUILD</div>
      <h1 class="header-title">Real projects.<br/><span class="accent-text">Real decisions.</span></h1>
      <p class="header-desc">We pull back the curtain on how Skyzer Networks builds websites — the choices, the process, and what actually worked.</p>
      <div class="header-stat">
        <span class="stat-num">{allPosts.length}</span>
        <span class="stat-label">Articles</span>
      </div>
    </div>
  </header>

  <main class="page-main">

    {allPosts.length === 0 && (
      <div class="empty-state">No builds documented yet — check back soon.</div>
    )}

    <!-- FEATURED AS FULL-WIDTH HERO CASE STUDY -->
    {featured && featuredData && (
      <section class="featured-section">
        <div class="section-eyebrow">Latest Build</div>
        <a href={`/behind-the-build/${featured.id}`} class="featured-post">
          <div class="fp-img">
            {featuredData.coverImage ? (
              <Image src={featuredData.coverImage} alt={featured.data.title} class="fp-cover" />
            ) : (
              <div class="fp-img-placeholder">
                <span>01</span>
              </div>
            )}
            <div class="fp-gradient"></div>
          </div>
          <div class="fp-content">
            <div class="fp-sub">
              {featured.data.subcategory && (
                <span class={`tag ${subMeta[featured.data.subcategory]?.colorClass ?? 'tag-a'}`}>
                  {subMeta[featured.data.subcategory]?.label ?? featured.data.subcategory}
                </span>
              )}
            </div>
            <h2 class="fp-title">{featured.data.title}</h2>
            <p class="fp-excerpt">{featured.data.description}</p>
            <div class="fp-footer">
              <span>{featured.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              <span class="fp-cta">Read the full breakdown →</span>
            </div>
          </div>
        </a>
      </section>
    )}

    <!-- REST: numbered editorial list -->
    {restWithImages.length > 0 && (
      <section class="builds-section">
        <div class="section-label">More Builds</div>
        <div class="builds-list">
          {restWithImages.map(({ post, coverImage }, i) => {
            const sub = subMeta[post.data.subcategory ?? ''] ?? { label: 'Behind the Build', colorClass: 'tag-a' };
            return (
              <a href={`/behind-the-build/${post.id}`} class="build-row">
                <div class="br-num">{String(i + 2).padStart(2, '0')}</div>
                <div class="br-img">
                  {coverImage ? (
                    <Image src={coverImage} alt={post.data.title} class="br-cover" />
                  ) : (
                    <div class="br-placeholder"></div>
                  )}
                </div>
                <div class="br-body">
                  <div class="br-tags">
                    <span class={`tag ${sub.colorClass}`}>{sub.label}</span>
                  </div>
                  <h3 class="br-title">{post.data.title}</h3>
                  <p class="br-excerpt">{post.data.description}</p>
                  <div class="br-meta">
                    <span>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                    <span>8 min read</span>
                  </div>
                </div>
                <div class="br-arrow">→</div>
              </a>
            );
          })}
        </div>
      </section>
    )}

  </main>
</Layout>

<style>
/* ── PAGE HEADER ── */
.page-header {
  position: relative;
  overflow: hidden;
  padding: 4rem 1.25rem 3rem;
  margin-top: var(--space-2xl);
  border-bottom: 0.5px solid var(--border);
}

.header-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 70% 60% at 110% 50%, rgba(255,170,0,0.06) 0%, transparent 70%),
    repeating-linear-gradient(
      0deg,
      transparent, transparent 59px,
      rgba(255,170,0,0.025) 59px,
      rgba(255,170,0,0.025) 60px
    );
  pointer-events: none;
}

.header-inner {
  position: relative;
  z-index: 1;
  max-width: 1160px;
  margin: 0 auto;
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
  margin-bottom: 1.5rem;
}

.breadcrumb a { color: var(--muted); text-decoration: none; }
.breadcrumb a:hover { color: #ffaa00; }
.breadcrumb span:last-child { color: #ffaa00; }

.header-tag {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  letter-spacing: 3px;
  color: #ffaa00;
  text-transform: uppercase;
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 10px;
}

.header-tag::before {
  content: '';
  width: 28px;
  height: 1px;
  background: #ffaa00;
}

.header-title {
  font-family: var(--font-title);
  font-size: var(--text-4xl);
  line-height: 1;
  letter-spacing: 1px;
  color: var(--white);
  margin-bottom: 1rem;
}

.accent-text {
  background: linear-gradient(90deg, #ffaa00, #ff6600);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.header-desc {
  font-size: var(--text-sm);
  color: rgba(245,243,239,0.55);
  max-width: 480px;
  line-height: 1.7;
  font-weight: 300;
  margin-bottom: 1.5rem;
}

.header-stat {
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.stat-num {
  font-family: var(--font-title);
  font-size: var(--text-3xl);
  color: #ffaa00;
  line-height: 1;
}

.stat-label {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
  letter-spacing: 1px;
  text-transform: uppercase;
}

/* ── MAIN ── */
.page-main {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 1.25rem 4rem;
}

.empty-state {
  font-size: var(--text-sm);
  color: var(--muted);
  font-family: var(--font-display);
  padding: 4rem 0;
  text-align: center;
}

/* ── FEATURED ── */
.featured-section {
  padding: 2.5rem 0 2.5rem;
  border-bottom: 0.5px solid var(--border);
  margin-bottom: 2.5rem;
}

.section-eyebrow {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  letter-spacing: 2px;
  text-transform: uppercase;
  color: #ffaa00;
  margin-bottom: 1.25rem;
}

.featured-post {
  display: flex;
  flex-direction: column;
  border: 0.5px solid rgba(255,170,0,0.2);
  border-radius: 8px;
  overflow: hidden;
  text-decoration: none;
  background: var(--card-bg);
  transition: border-color 0.2s;
}

.featured-post:hover { border-color: rgba(255,170,0,0.45); }

.fp-img {
  position: relative;
  height: 260px;
  background: #1a1000;
  overflow: hidden;
}

.fp-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.fp-gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(to bottom, transparent 50%, rgba(10,8,0,0.7));
}

.fp-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1a1000, #120e00);
}

.fp-img-placeholder span {
  font-family: var(--font-title);
  font-size: 5rem;
  letter-spacing: 4px;
  color: rgba(255,170,0,0.08);
}

.fp-content {
  padding: 1.75rem;
}

.fp-sub { margin-bottom: 0.75rem; }

.fp-title {
  font-family: var(--font-sub);
  font-size: var(--text-2xl);
  line-height: 1.2;
  color: var(--white);
  margin-bottom: 0.75rem;
  letter-spacing: 0.5px;
}

.fp-excerpt {
  font-size: var(--text-sm);
  color: rgba(245,243,239,0.55);
  font-weight: 300;
  line-height: 1.7;
  margin-bottom: 1.25rem;
}

.fp-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
  border-top: 0.5px solid var(--border);
  padding-top: 1rem;
}

.fp-cta { color: #ffaa00; }

/* ── BUILDS LIST ── */
.section-label {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 1.25rem;
  display: flex;
  align-items: center;
  gap: 10px;
}

.section-label::after {
  content: '';
  flex: 1;
  height: 0.5px;
  background: var(--border);
}

.builds-list {
  display: flex;
  flex-direction: column;
}

.build-row {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding: 1.25rem 0;
  border-bottom: 0.5px solid var(--border);
  text-decoration: none;
  transition: background 0.15s;
  border-radius: 4px;
}

.build-row:last-child { border-bottom: none; }
.build-row:hover { background: rgba(255,170,0,0.02); }

.br-num {
  font-family: var(--font-title);
  font-size: var(--text-2xl);
  color: rgba(255,170,0,0.12);
  width: 36px;
  flex-shrink: 0;
  line-height: 1;
  padding-top: 4px;
}

.br-img {
  width: 90px;
  height: 65px;
  border-radius: 4px;
  overflow: hidden;
  flex-shrink: 0;
  background: #1a1000;
}

.br-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.br-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1a1000, #0f0c00);
}

.br-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.br-tags { display: flex; gap: 5px; }

.br-title {
  font-family: var(--font-sub);
  font-size: var(--text-md);
  color: var(--white);
  font-weight: 500;
  line-height: 1.35;
}

.br-excerpt {
  font-size: var(--text-sm);
  color: rgba(245,243,239,0.45);
  font-weight: 300;
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.br-meta {
  display: flex;
  gap: 10px;
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
}

.br-arrow {
  font-size: var(--text-md);
  color: rgba(255,170,0,0.3);
  flex-shrink: 0;
  padding-top: 4px;
  transition: color 0.2s, transform 0.2s;
}

.build-row:hover .br-arrow {
  color: #ffaa00;
  transform: translateX(3px);
}

/* Tags */
.tag {
  display: inline-block;
  font-size: var(--text-xs);
  font-family: var(--font-display);
  padding: 3px 8px;
  border-radius: 2px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  border: 0.5px solid var(--border);
  background: rgba(255,255,255,0.05);
  color: var(--muted);
}

.tag-c { border-color: rgba(0,200,255,0.3);   color: var(--blue);    background: rgba(0,200,255,0.05); }
.tag-m { border-color: rgba(204,0,255,0.3);   color: #cc66ff;        background: rgba(204,0,255,0.05); }
.tag-g { border-color: rgba(0,255,136,0.3);   color: #00dd77;        background: rgba(0,255,136,0.05); }
.tag-a { border-color: rgba(255,170,0,0.3);   color: #ffaa00;        background: rgba(255,170,0,0.05); }
.tag-w { border-color: rgba(200,200,200,0.2); color: #c8c8c8;        background: rgba(200,200,200,0.04); }

/* ── MEDIA QUERIES ── */

/* sm — large phones (480px+) */
@media (min-width: 480px) {
  .br-img {
    width: 110px;
    height: 78px;
  }
}

/* md — tablets (768px+) */
@media (min-width: 768px) {
  .page-header { padding: 5rem 2rem 3.5rem; }
  .header-title { font-size: var(--text-5xl); }
  .page-main { padding: 0 2rem 4rem; }

  .featured-post {
    flex-direction: row;
  }

  .fp-img {
    width: 420px;
    height: auto;
    flex-shrink: 0;
  }

  .fp-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .fp-title { font-size: var(--text-3xl); }

  .br-img {
    width: 130px;
    height: 90px;
  }

  .br-excerpt { -webkit-line-clamp: 3; }
}

/* lg — laptops (1024px+) */
@media (min-width: 1024px) {
  .br-num { font-size: var(--text-3xl); width: 44px; }

  .br-img {
    width: 150px;
    height: 100px;
  }
}

/* xl — standard desktops (1280px+) */
@media (min-width: 1280px) {
  .fp-img { width: 500px; }
}
</style>