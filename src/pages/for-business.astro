---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { getPostImage } from '@/lib/getPostImage';

const allPosts = (await getCollection('for-business').catch(() => []))
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const featured = allPosts.find(p => p.data.featured) ?? allPosts[0];
const rest = allPosts.filter(p => p !== featured);

const postsWithImages = await Promise.all(
  allPosts.map(async (post) => ({
    post,
    coverImage: post.data.cover ? await getPostImage(post.data.cover) : null,
  }))
);

const featuredData = postsWithImages.find(({ post }) => post === featured);
const restWithImages = postsWithImages.filter(({ post }) => post !== featured);

const subMeta: Record<string, { label: string; colorClass: string }> = {
  'case-study':   { label: 'Case Study',   colorClass: 'tag-c' },
  'for-business': { label: 'For Business', colorClass: 'tag-c' },
  'ecommerce':    { label: 'E-Commerce',   colorClass: 'tag-w' },
  'guide':        { label: 'Guide',        colorClass: 'tag-w' },
};
---

<Layout
  title="For Business | 24 Hour Journey"
  description="Business-focused articles on building websites, growing online, and making smart tech choices for small businesses and creators."
  url="https://24hourjourney.blog/for-business"
  image_preview="/icons/preview.png"
  type="website"
>
  <!-- PAGE HEADER -->
  <header class="page-header">
    <div class="header-bg"></div>
    <div class="header-inner">
      <div class="breadcrumb"><a href="/">Home</a><span>/</span><span>For Business</span></div>
      <div class="header-tag">FOR BUSINESS</div>
      <h1 class="header-title">Grow your<br/><span class="accent-text">online presence.</span></h1>
      <p class="header-desc">Websites, strategy, and honest advice for small businesses ready to make their mark online.</p>
      <div class="header-stat">
        <span class="stat-num">{allPosts.length}</span>
        <span class="stat-label">articles</span>
      </div>
    </div>
  </header>

  <main class="page-main">

    {featured && featuredData ? (
      <!-- FEATURED HERO POST -->
      <section class="featured-section">
        <a href={`/for-business/${featured.id}`} class="featured-post">
          <div class="fp-img">
            {featuredData.coverImage ? (
              <Image src={featuredData.coverImage} alt={featured.data.title} class="fp-cover" />
            ) : (
              <div class="fp-img-placeholder"><span>FOR BUSINESS</span></div>
            )}
            <div class="fp-badge">Featured</div>
          </div>
          <div class="fp-body">
            <div class="fp-sub">
              {featured.data.subcategory && (
                <span class={`tag ${subMeta[featured.data.subcategory]?.colorClass ?? 'tag-c'}`}>
                  {subMeta[featured.data.subcategory]?.label ?? featured.data.subcategory}
                </span>
              )}
            </div>
            <h2 class="fp-title">{featured.data.title}</h2>
            <p class="fp-excerpt">{featured.data.description}</p>
            <div class="fp-footer">
              <span class="fp-date">{featured.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
              <span class="fp-read">Read article →</span>
            </div>
          </div>
        </a>
      </section>
    ) : null}

    <!-- ALL ARTICLES -->
    {restWithImages.length > 0 && (
      <section class="articles-section">
        <div class="section-label">All Articles</div>
        <div class="articles-grid">
          {restWithImages.map(({ post, coverImage }) => {
            const sub = subMeta[post.data.subcategory ?? ''] ?? { label: 'For Business', colorClass: 'tag-c' };
            return (
              <a href={`/for-business/${post.id}`} class="article-card">
                <div class="ac-img">
                  {coverImage ? (
                    <Image src={coverImage} alt={post.data.title} class="ac-cover" />
                  ) : (
                    <div class="ac-placeholder"><span>BIZ</span></div>
                  )}
                </div>
                <div class="ac-body">
                  <span class={`tag ${sub.colorClass}`}>{sub.label}</span>
                  <h3 class="ac-title">{post.data.title}</h3>
                  <p class="ac-excerpt">{post.data.description}</p>
                  <div class="ac-footer">
                    <span>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                    <span>5 min</span>
                  </div>
                </div>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {allPosts.length === 0 && (
      <div class="empty-state">No posts yet — check back soon.</div>
    )}

  </main>
</Layout>

<style>

/* ── PAGE HEADER ── */
.page-header {
  position: relative;
  overflow: hidden;
  padding: 4rem 1.25rem 3rem;
  margin-top: var(--space-2xl);
  border-bottom: 0.5px solid var(--border);
}

.header-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 60% 80% at 100% 50%, rgba(0,200,255,0.08) 0%, transparent 70%),
    repeating-linear-gradient(
      90deg,
      transparent, transparent 79px,
      rgba(0,200,255,0.04) 79px,
      rgba(0,200,255,0.04) 80px
    );
  pointer-events: none;
}

.header-inner {
  position: relative;
  z-index: 1;
  max-width: 1160px;
  margin: 0 auto;
}

.breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
  margin-bottom: 1.5rem;
}

.breadcrumb a { color: var(--muted); text-decoration: none; }
.breadcrumb a:hover { color: var(--blue); }
.breadcrumb span:last-child { color: var(--blue); }

.header-tag {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  letter-spacing: 3px;
  color: var(--blue);
  text-transform: uppercase;
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 10px;
}

.header-tag::before {
  content: '';
  width: 28px;
  height: 1px;
  background: var(--blue);
}

.header-title {
  font-family: var(--font-title);
  font-size: var(--text-4xl);
  line-height: 1;
  letter-spacing: 1px;
  color: var(--white);
  margin-bottom: 1rem;
}

.accent-text {
  background: linear-gradient(90deg, var(--blue), var(--purple));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.header-desc {
  font-size: var(--text-sm);
  color: rgba(245,243,239,0.55);
  max-width: 480px;
  line-height: 1.7;
  font-weight: 300;
  margin-bottom: 1.5rem;
}

.header-stat {
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.stat-num {
  font-family: var(--font-title);
  font-size: var(--text-3xl);
  color: var(--blue);
  line-height: 1;
}

.stat-label {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
  letter-spacing: 1px;
  text-transform: uppercase;
}

/* ── MAIN ── */
.page-main {
  max-width: 1160px;
  margin: 0 auto;
  padding: 0 1.25rem 4rem;
}

.empty-state {
  font-size: var(--text-sm);
  color: var(--muted);
  font-family: var(--font-display);
  padding: 4rem 0;
  text-align: center;
}

/* ── FEATURED POST ── */
.featured-section {
  padding: 2.5rem 0 2rem;
  border-bottom: 0.5px solid var(--border);
  margin-bottom: 2.5rem;
}

.featured-post {
  display: flex;
  flex-direction: column;
  background: var(--card-bg);
  border: 0.5px solid rgba(0,200,255,0.2);
  border-radius: 8px;
  overflow: hidden;
  text-decoration: none;
  transition: border-color 0.2s;
}

.featured-post:hover { border-color: rgba(0,200,255,0.5); }

.fp-img {
  position: relative;
  height: 240px;
  background: #0d1520;
  overflow: hidden;
}

.fp-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.fp-img-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #0d1520, #0a1a2e);
}

.fp-img-placeholder span {
  font-family: var(--font-title);
  font-size: var(--text-4xl);
  letter-spacing: 4px;
  color: rgba(0,200,255,0.12);
}

.fp-badge {
  position: absolute;
  top: 14px;
  left: 14px;
  background: rgba(0,200,255,0.1);
  border: 0.5px solid rgba(0,200,255,0.35);
  color: var(--blue);
  font-family: var(--font-display);
  font-size: var(--text-xs);
  letter-spacing: 1.5px;
  padding: 4px 10px;
  border-radius: 2px;
  text-transform: uppercase;
}

.fp-body {
  padding: 1.5rem;
}

.fp-sub {
  margin-bottom: 0.75rem;
}

.fp-title {
  font-family: var(--font-sub);
  font-size: var(--text-2xl);
  line-height: 1.2;
  color: var(--white);
  margin-bottom: 0.75rem;
  letter-spacing: 0.5px;
}

.fp-excerpt {
  font-size: var(--text-sm);
  color: rgba(245,243,239,0.55);
  font-weight: 300;
  line-height: 1.7;
  margin-bottom: 1.25rem;
}

.fp-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 0.5px solid var(--border);
  padding-top: 1rem;
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
}

.fp-read { color: var(--blue); }

/* ── ARTICLES GRID ── */
.section-label {
  font-family: var(--font-display);
  font-size: var(--text-xs);
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 1.25rem;
  display: flex;
  align-items: center;
  gap: 10px;
}

.section-label::after {
  content: '';
  flex: 1;
  height: 0.5px;
  background: var(--border);
}

.articles-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}

.article-card {
  display: flex;
  flex-direction: column;
  background: var(--card-bg);
  border: 0.5px solid var(--border);
  border-radius: 6px;
  overflow: hidden;
  text-decoration: none;
  transition: border-color 0.2s, transform 0.2s;
}

.article-card:hover {
  border-color: rgba(0,200,255,0.3);
  transform: translateY(-2px);
}

.ac-img {
  height: 160px;
  background: #0d1520;
  overflow: hidden;
  position: relative;
}

.ac-cover {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.ac-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #0a1018, #0d1520);
}

.ac-placeholder span {
  font-family: var(--font-title);
  font-size: var(--text-3xl);
  letter-spacing: 3px;
  color: rgba(0,200,255,0.08);
}

.ac-body {
  padding: 1rem 1.1rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  flex: 1;
}

.ac-title {
  font-family: var(--font-sub);
  font-size: var(--text-md);
  color: var(--white);
  line-height: 1.4;
  font-weight: 500;
}

.ac-excerpt {
  font-size: var(--text-sm);
  color: rgba(245,243,239,0.48);
  font-weight: 300;
  line-height: 1.6;
  flex: 1;
}

.ac-footer {
  display: flex;
  justify-content: space-between;
  font-family: var(--font-display);
  font-size: var(--text-xs);
  color: var(--muted);
  border-top: 0.5px solid var(--border);
  padding-top: 0.75rem;
  margin-top: 0.25rem;
}

/* Tags (shared) */
.tag {
  background: rgba(255,255,255,0.05);
  border: 0.5px solid var(--border);
  color: var(--muted);
  font-size: var(--text-xs);
  font-family: var(--font-display);
  padding: 3px 8px;
  border-radius: 2px;
  letter-spacing: 0.5px;
  text-transform: uppercase;
  display: inline-block;
}

.tag-c { border-color: rgba(0,200,255,0.3);   color: var(--blue);    background: rgba(0,200,255,0.05); }
.tag-m { border-color: rgba(204,0,255,0.3);   color: #cc66ff;        background: rgba(204,0,255,0.05); }
.tag-g { border-color: rgba(0,255,136,0.3);   color: #00dd77;        background: rgba(0,255,136,0.05); }
.tag-a { border-color: rgba(255,170,0,0.3);   color: #ffaa00;        background: rgba(255,170,0,0.05); }
.tag-w { border-color: rgba(200,200,200,0.2); color: #c8c8c8;        background: rgba(200,200,200,0.04); }

/* ── MEDIA QUERIES ── */

/* sm — large phones (480px+) */
@media (min-width: 480px) {
  .articles-grid {
    grid-template-columns: 1fr 1fr;
  }
}

/* md — tablets (768px+) */
@media (min-width: 768px) {
  .page-header {
    padding: 5rem 2rem 3.5rem;
  }

  .header-title {
    font-size: var(--text-5xl);
  }

  .page-main {
    padding: 0 2rem 4rem;
  }

  .featured-post {
    flex-direction: row;
  }

  .fp-img {
    width: 380px;
    height: auto;
    flex-shrink: 0;
  }

  .fp-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .fp-title {
    font-size: var(--text-3xl);
  }
}

/* lg — laptops (1024px+) */
@media (min-width: 1024px) {
  .articles-grid {
    grid-template-columns: repeat(3, 1fr);
  }

  .fp-img {
    width: 460px;
  }
}

/* xl — standard desktops (1280px+) */
@media (min-width: 1280px) {
  .articles-grid {
    grid-template-columns: repeat(4, 1fr);
  }
}
</style>